    {
      "parameters": {
        "text": "=You are a professional resume writer. Using the following information, create a detailed and professional resume in structured text format:\n\nName: {{ $json.body['Full Name'] }}\nEmail: {{ $json.body['Email'] }}\nWork Experience: {{ $json.body['Work Experience'] }}\nSkills: {{ $json.body['Skills'] }}\nEducation: {{ $json.body['Education'] }}\n\nCreate a comprehensive resume with all standard sections.",
        "options": {
          "systemMessage": "You are an expert resume writer. Generate professional, ATS-optimized resumes."
        }
      },
