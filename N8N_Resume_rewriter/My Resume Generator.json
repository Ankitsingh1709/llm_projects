      "parameters": {
        "text": "=Convert the following resume content into clean, professional LaTeX code. Use the 'moderncv' template with 'classic' style and 'blue' color. Only output the raw LaTeX code, nothing else:\n\n{{ $json.output }}",
        "options": {
          "systemMessage": "/no_think\nYou are a LaTeX expert. Convert resume content to LaTeX using moderncv template. Output only raw LaTeX code."
        }
