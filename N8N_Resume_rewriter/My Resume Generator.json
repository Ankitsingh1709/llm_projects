    {
      "parameters": {
        "url": "=https://www.overleaf.com/project/{{ $json.body.project_id }}/output/output.pdf",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Cookie",
              "value": "={{ $('Extract curl').item.json.session_cookie }}"
            }
