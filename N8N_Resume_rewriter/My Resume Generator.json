    {
      "parameters": {
        "jsCode": "// Step 1: Code in JavaScript\n// Extract and prepare form data for processing\nconst items = $input.all();\nconst formData = items[0].json;\n\n// Build structured data object\nconst resumeData = {\n  name: formData.body?.['Full Name'] || formData['Full Name'] || '',\n  email: formData.body?.['Email'] || formData['Email'] || '',\n  experience: formData.body?.['Work Experience'] || formData['Work Experience'] || '',\n  skills: formData.body?.['Skills'] || formData['Skills'] || '',\n  education: formData.body?.['Education'] || formData['Education'] || '',\n  timestamp: new Date().toISOString()\n};\n\nreturn [{ json: resumeData }];"
      },
      "id": "ddf35cb4-fde6-45d1-89cd-9100982d3e7a",
      "name": "Code in JavaScript",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "fields": {
          "values": [
            {
              "name": "overleaf_email",
              "stringValue": "your-overleaf-email@example.com"
            },
            {
              "name": "overleaf_password",
              "stringValue": "your-overleaf-password"
            },
            {
              "name": "project_name",
              "stringValue": "=Resume - {{ $('Code in JavaScript').item.json.name }}"
            }
          ]
        },
        "options": {}
      },
      "id": "31683b59-b3ce-4d5d-b534-e8ffd62a8198",
      "name": "Edit Fields3",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3,
      "position": [
        224,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "// Step 3: Decode Cookie Key\n// Prepare auth credentials for Overleaf\nconst items = $input.all();\nconst data = items[0].json;\n\n// Encode credentials for Overleaf authentication\nconst credentials = {\n  email: data.overleaf_email,\n  password: data.overleaf_password,\n  projectName: data.project_name,\n  encodedAuth: Buffer.from(`${data.overleaf_email}:${data.overleaf_password}`).toString('base64')\n};\n\nreturn [{ json: { ...data, ...credentials } }];"
      },
      "id": "79262304-91a7-4b40-959d-987e7128d519",
      "name": "Decode Cookie key",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        0
      ]
    },
    {
      "parameters": {
        "url": "https://www.overleaf.com/login",
        "options": {
          "response": {
            "response": {
              "fullResponse": true,
              "responseFormat": "text"
            }
          }
        }
      },
      "id": "126f2887-015a-4fb7-b478-7b05356af8c1",
      "name": "Connect Overleaf",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        0,
        224
      ]
    },
    {
      "parameters": {
        "jsCode": "// Step 5: Extract curl / CSRF token from Overleaf login page\nconst items = $input.all();\nconst responseBody = items[0].json.body || '';\nconst headers = items[0].json.headers || {};\n\n// Extract CSRF token from page\nconst csrfMatch = responseBody.match(/name=\"_csrf\"[^>]*value=\"([^\"]+)\"/) ||\n                  responseBody.match(/csrf-token\"\\s+content=\"([^\"]+)\"/);\nconst csrfToken = csrfMatch ? csrfMatch[1] : '';\n\n// Extract session cookie\nconst setCookieHeader = headers['set-cookie'] || [];\nconst sessionCookie = Array.isArray(setCookieHeader)\n  ? setCookieHeader.join('; ')\n  : setCookieHeader;\n\nreturn [{ json: {\n  ...items[0].json,\n  csrf_token: csrfToken,\n  session_cookie: sessionCookie\n}}];"
      },
      "id": "7d08b55a-d4a4-4d10-b38b-29ad9db60f36",
      "name": "Extract curl",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        224,
        224
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://www.overleaf.com/api/project",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            },
            {
              "name": "Cookie",
              "value": "={{ $json.session_cookie }}"
            },
            {
              "name": "X-CSRF-Token",
              "value": "={{ $json.csrf_token }}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "name",
              "value": "={{ $('Edit Fields3').item.json.project_name }}"
            }
          ]
        },
        "options": {
          "response": {
            "response": {
              "fullResponse": true
            }
          }
        }
      },
      "id": "b4a87a9c-3064-494d-9ce2-131ade144f96",
      "name": "Create Project and Paste Latex",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        448,
