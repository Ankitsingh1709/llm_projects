      "id": "85fcf916-d157-4d5a-9164-d17ff48ce0cf",
      "name": "Generate Resume PDF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        752,
        192
      ]
    },
    {
      "parameters": {
        "jsCode": "// Extract project ID and prepare for compilation\nconst items = $input.all();\nconst response = items[0].json;\n\nconst projectId = response.body?.project_id ||\n                  response.body?._id ||\n                  response.project_id || '';\n\nreturn [{ json: {\n  ...response,\n  project_id: projectId\n}}];"
      },
      "id": "5401128e-fa6c-4307-913a-0fe1152d0b31",
      "name": "Extract",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        0,
        448
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://www.overleaf.com/project/{{ $json.project_id }}/compile",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Cookie",
              "value": "={{ $('Extract curl').item.json.session_cookie }}"
            },
            {
              "name": "X-CSRF-Token",
              "value": "={{ $('Extract curl').item.json.csrf_token }}"
            }
          ]
        },
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "check",
              "value": "silent"
            },
            {
              "name": "draft",
              "value": "false"
            },
            {
              "name": "stopOnFirstError",
              "value": "false"
            }
          ]
        },
        "options": {}
      },
      "id": "00f28e03-975a-49cb-a03e-62b61cccce99",
      "name": "Project Compiler",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [
        224,
        448
      ]
    },
    {
      "parameters": {
        "jsCode": "// Final step: Rendered Resume PDF\n// Package the final output\nconst items = $input.all();\nconst compileResult = items[0].json;\n\nconst status = compileResult.body?.status || compileResult.status || 'unknown';\nconst outputFiles = compileResult.body?.outputFiles || [];\nconst pdfFile = outputFiles.find(f => f.type === 'pdf') || {};\n\nreturn [{ json: {\n  success: status === 'success',\n  status: status,\n  pdf_url: pdfFile.url || '',\n  pdf_path: pdfFile.path || '',\n  project_id: $('Extract').item.json.project_id,\n  message: status === 'success'\n    ? 'Resume PDF generated successfully!'\n    : `Compilation status: ${status}`,\n  timestamp: new Date().toISOString()\n}}];"
      },
      "id": "338e482f-be71-4e73-9fa6-be15f8a92b65",
      "name": "Rendered Resume PDF",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        448,
        448
      ]
    }
